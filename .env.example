# Local LLM Data Analyst — Environment Configuration
# Copy this file to .env and fill in your values.
# This file is committed to the repository as a reference.
# The actual .env file should NEVER be committed.

# Ollama server URL (default: http://127.0.0.1:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default LLM model name (must be pulled in Ollama first)
DEFAULT_MODEL=qwen2.5-coder:7b

# Streamlit server port (default: 8501)
STREAMLIT_SERVER_PORT=8501

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
